# Mapbox GL JS token (obligatorio para MapboxMap)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps JavaScript API key (obligatoria para GoogleMapView)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Estilo opcional para MapLibre (si no se define usa demotiles.maplibre.org)
NEXT_PUBLIC_MAPLIBRE_STYLE_URL=

# Routing peatonal por defecto (gratuito y libre, sin API key)
# Servicio recomendado: https://routing.openstreetmap.de/routed-foot
NEXT_PUBLIC_OSRM_WALKING_BASE_URL=
NEXT_PUBLIC_OSRM_WALKING_PROFILE=

# Fallback peatonal opcional
NEXT_PUBLIC_OSRM_WALKING_FALLBACK_BASE_URL=
NEXT_PUBLIC_OSRM_WALKING_FALLBACK_PROFILE=

# Endpoint de driving opcional (no usado en modo fijo a pie de este MVP)
NEXT_PUBLIC_OSRM_DRIVING_BASE_URL=
NEXT_PUBLIC_OSRM_DRIVING_PROFILE=
